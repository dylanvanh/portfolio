---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const formatDate = (date: Date) =>
  date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "short",
    day: "numeric",
  });
---

<Layout
  title="Blog"
  description="Technical writing by Dylan van Heerden about Bitcoin, the Internet Computer, and software engineering."
>
  <main class="mx-auto max-w-[720px] px-6 py-12">
    <header class="mb-12">
      <a
        href="/"
        data-astro-prefetch
        class="text-accent hover:text-primary mb-6 inline-flex items-center gap-2 text-sm transition-colors"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="m15 18-6-6 6-6"></path>
        </svg>
        Home
      </a>
      <div class="flex items-center justify-between gap-6">
        <h1 class="text-primary text-3xl font-bold md:text-4xl">Blog</h1>
        <a
          href="/rss.xml"
          class="text-accent hover:text-primary text-sm transition-colors"
          >RSS</a
        >
      </div>
      <p class="text-secondary mt-2">Works on my machine, documented here.</p>
    </header>

    {
      posts.length === 0 ? (
        <p class="text-accent">No posts yet. Check back soon!</p>
      ) : (
        <ul class="space-y-8">
          {posts.map((post) => (
            <li>
              <a
                href={`/blog/${post.id}`}
                data-astro-prefetch
                class="group hover:bg-accent/5 block rounded-lg border border-gray-800 p-6 transition-colors hover:border-gray-700"
              >
                <time
                  datetime={post.data.pubDate.toISOString()}
                  class="text-accent text-sm"
                >
                  {formatDate(post.data.pubDate)}
                </time>
                <h2 class="text-primary group-hover:text-secondary mt-2 text-xl font-semibold transition-colors">
                  {post.data.title}
                </h2>
                <p class="text-secondary mt-2">{post.data.description}</p>
                {post.data.tags && post.data.tags.length > 0 && (
                  <div class="mt-4 flex flex-wrap gap-2">
                    {post.data.tags.map((tag) => (
                      <span class="bg-accent/10 text-accent rounded-full px-3 py-1 text-xs">
                        {tag}
                      </span>
                    ))}
                  </div>
                )}
              </a>
            </li>
          ))}
        </ul>
      )
    }
  </main>
</Layout>
