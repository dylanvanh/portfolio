---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const formatDate = (date: Date) =>
  date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "short",
    day: "numeric",
  });
---

<Layout
  title="Blog"
  description="Technical writing by Dylan van Heerden about Bitcoin, the Internet Computer, and software engineering."
>
  <main class="mx-auto max-w-[760px] px-6 py-8 sm:px-8 sm:py-12">
    <header class="mb-16">
      <a
        href="/"
        data-astro-prefetch
        class="text-secondary hover:text-primary mb-16 inline-flex items-center gap-2 text-sm transition-colors duration-150"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="m15 18-6-6 6-6"></path>
        </svg>
        Home
      </a>
      <div class="flex items-end justify-between gap-6">
        <h1
          class="text-primary text-4xl font-semibold text-balance sm:text-5xl"
        >
          Writing
        </h1>
        <a
          href="/rss.xml"
          class="text-secondary hover:text-primary pb-1 text-sm transition-colors duration-150"
          >RSS</a
        >
      </div>
      <p class="text-secondary mt-5 max-w-xl text-lg leading-8 text-pretty">
        Notes on Bitcoin, the Internet Computer, and building software.
      </p>
    </header>

    {
      posts.length === 0 ? (
        <p class="text-accent">No posts yet. Check back soon!</p>
      ) : (
        <ul class="divide-border border-border divide-y border-t">
          {posts.map((post) => (
            <li>
              <a
                href={`/blog/${post.id}`}
                data-astro-prefetch
                class="group block py-7"
              >
                <time
                  datetime={post.data.pubDate.toISOString()}
                  class="text-accent text-sm tabular-nums"
                >
                  {formatDate(post.data.pubDate)}
                </time>
                <h2 class="text-primary group-hover:text-accent mt-2 text-xl font-medium text-balance transition-colors duration-150">
                  {post.data.title}
                </h2>
                <p class="text-secondary mt-2 leading-7 text-pretty">
                  {post.data.description}
                </p>
                {post.data.tags && post.data.tags.length > 0 && (
                  <div class="mt-4 flex flex-wrap gap-2">
                    {post.data.tags.map((tag) => (
                      <span class="text-accent text-xs">{tag}</span>
                    ))}
                  </div>
                )}
              </a>
            </li>
          ))}
        </ul>
      )
    }
  </main>
</Layout>
