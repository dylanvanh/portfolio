---
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";
import ExperienceCard from "../components/ExperienceCard.astro";
import ProjectCard from "../components/ProjectCard.astro";
import ToolBadge from "../components/ToolBadge.astro";
import type { ExperienceItem } from "../types/ExperienceItem";
import type { ProjectItem } from "../types/ProjectItem";
import type {
  EnvironmentItem,
  EnvironmentItems,
} from "../types/EnvironmentItem";
import rawExperienceItems from "../content/data/experience.json";
import rawProjectsItems from "../content/data/projects.json";
import rawEnvironmentItems from "../content/data/environment.json";
import { SITE_DESCRIPTION, SITE_NAME, SOCIAL_PROFILE_URLS } from "../lib/site";

const experienceItems: ExperienceItem[] =
  rawExperienceItems as ExperienceItem[];

const projectsItems: ProjectItem[] = rawProjectsItems as ProjectItem[];

const environmentItems: EnvironmentItems =
  rawEnvironmentItems as EnvironmentItems;

const currentYear = new Date().getFullYear();
const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "@id": new URL("/#person", Astro.site).href,
  name: SITE_NAME,
  url: new URL("/", Astro.site).href,
  jobTitle: "Software Engineer",
  homeLocation: {
    "@type": "Place",
    name: "Cape Town, South Africa",
  },
  sameAs: SOCIAL_PROFILE_URLS,
};
---

<Layout
  title={SITE_NAME}
  description={SITE_DESCRIPTION}
  structuredData={personSchema}
>
  <main id="top" class="mx-auto max-w-[760px] px-6 py-8 sm:px-8 sm:py-12">
    <header class="mb-20 sm:mb-24">
      <nav
        class="mb-16 flex items-center justify-between sm:mb-20"
        aria-label="Primary navigation"
      >
        <a href="/" class="text-primary text-sm font-medium">DVH</a>
        <div class="text-secondary flex items-center gap-5 text-sm">
          <a
            class="hover:text-primary transition-colors duration-150"
            href="#work">Work</a
          >
          <a
            class="hover:text-primary transition-colors duration-150"
            href="/blog"
            data-astro-prefetch>Writing</a
          >
        </div>
      </nav>

      <div class="max-w-2xl">
        <p class="text-accent mb-4 text-sm">Software engineer · Cape Town</p>
        <h1
          class="text-primary text-4xl font-semibold text-balance sm:text-5xl"
        >
          {SITE_NAME}
        </h1>
        <p class="text-secondary mt-6 max-w-xl text-lg leading-8 text-pretty">
          I build specialised software across AI, crypto infrastructure, and the
          web.
        </p>
        <div class="mt-8 flex flex-wrap items-center gap-x-5 gap-y-3">
          <a
            class="text-secondary hover:text-primary inline-flex items-center gap-2 text-sm transition-colors duration-150"
            href="https://www.linkedin.com/in/dylanvanheerden/"
            aria-label="LinkedIn profile"
            target="_blank"
            rel="noopener noreferrer"
          >
            <Image
              class="size-4 opacity-70"
              src="/linkedin.svg"
              alt=""
              width="16"
              height="16"
            />
            LinkedIn
          </a>
          <a
            class="text-secondary hover:text-primary inline-flex items-center gap-2 text-sm transition-colors duration-150"
            href="https://github.com/dylanvanh"
            aria-label="GitHub profile"
            target="_blank"
            rel="noopener noreferrer"
          >
            <Image
              class="size-4 opacity-70"
              src="/github.svg"
              alt=""
              width="16"
              height="16"
            />
            GitHub
          </a>
          <a
            class="text-secondary hover:text-primary inline-flex items-center gap-2 text-sm transition-colors duration-150"
            href="https://x.com/obonobza"
            aria-label="X profile"
            target="_blank"
            rel="noopener noreferrer"
          >
            <Image
              class="size-4 opacity-70"
              src="/x.svg"
              alt=""
              width="16"
              height="16"
            />
            X
          </a>
          <a
            class="text-secondary hover:text-primary inline-flex items-center gap-2 text-sm transition-colors duration-150"
            href="mailto:dylanvanh45@gmail.com"
            aria-label="Send Dylan an email"
          >
            <Image
              class="size-4 opacity-70"
              src="/at-sign.svg"
              alt=""
              width="16"
              height="16"
            />
            Email
          </a>
        </div>
      </div>
    </header>

    <section id="work" class="border-border border-t py-12 sm:py-16">
      <div class="grid gap-8 sm:grid-cols-[140px_1fr]">
        <h2 class="text-primary text-sm font-medium">Experience</h2>
        <div class="space-y-10">
          {
            experienceItems.map((item) => (
              <ExperienceCard
                period={item.period}
                company={item.company}
                position={item.position}
                technologies={item.technologies}
              />
            ))
          }
        </div>
      </div>
    </section>

    <section class="border-border border-t py-12 sm:py-16">
      <div class="grid gap-8 sm:grid-cols-[140px_1fr]">
        <h2 class="text-primary text-sm font-medium">Selected projects</h2>
        <div class="divide-border min-w-0 divide-y">
          {
            projectsItems.map((item) => (
              <ProjectCard
                title={item.title}
                href={item.href}
                websiteUrl={item.websiteUrl}
                technologies={item.technologies}
                primaryLinkAriaLabel={item.primaryLinkAriaLabel}
              />
            ))
          }
        </div>
      </div>
    </section>

    <section class="border-border border-t py-12 sm:py-16">
      <div class="grid gap-8 sm:grid-cols-[140px_1fr]">
        <h2 class="text-primary text-sm font-medium">Environment</h2>
        <div class="space-y-7">
          <div>
            <div class="text-secondary mb-3 flex items-center gap-2 text-sm">
              <h3>Unix</h3>
              <Image
                class="size-4"
                src="/mac.svg"
                alt=""
                width="16"
                height="16"
              />
              <Image
                class="size-4"
                src="/linux.svg"
                alt=""
                width="16"
                height="16"
              />
            </div>
            <div class="flex flex-wrap gap-x-4 gap-y-2">
              {
                environmentItems.unix.map((item: EnvironmentItem) => (
                  <ToolBadge name={item.name} href={item.href} />
                ))
              }
            </div>
          </div>

          <div>
            <div class="text-secondary mb-3 flex items-center gap-2 text-sm">
              <h3>Windows</h3>
              <Image
                class="size-4"
                src="/windows.svg"
                alt=""
                width="16"
                height="16"
              />
            </div>
            <div class="flex flex-wrap gap-x-4 gap-y-2">
              {
                environmentItems.windows.map((item: EnvironmentItem) => (
                  <ToolBadge name={item.name} href={item.href} />
                ))
              }
            </div>
          </div>
        </div>
      </div>
    </section>

    <footer
      class="border-border flex flex-col gap-2 border-t py-8 text-sm sm:flex-row sm:items-center sm:justify-between"
    >
      <p class="text-secondary">© {currentYear} Dylan van Heerden</p>
      <a
        class="text-accent hover:text-primary transition-colors duration-150"
        href="#top">Back to top ↑</a
      >
    </footer>
  </main>
</Layout>
