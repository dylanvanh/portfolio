---
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";
import ExperienceCard from "../components/ExperienceCard.astro";
import ProjectCard from "../components/ProjectCard.astro";
import ToolBadge from "../components/ToolBadge.astro";
import type { ExperienceItem } from "../types/ExperienceItem";
import type { ProjectItem } from "../types/ProjectItem";
import type {
  EnvironmentItem,
  EnvironmentItems,
} from "../types/EnvironmentItem";
import rawExperienceItems from "../content/data/experience.json";
import rawProjectsItems from "../content/data/projects.json";
import rawEnvironmentItems from "../content/data/environment.json";
import { SITE_DESCRIPTION, SITE_NAME, SOCIAL_PROFILE_URLS } from "../lib/site";

const experienceItems: ExperienceItem[] =
  rawExperienceItems as ExperienceItem[];

const projectsItems: ProjectItem[] = rawProjectsItems as ProjectItem[];

const environmentItems: EnvironmentItems =
  rawEnvironmentItems as EnvironmentItems;

const currentYear = new Date().getFullYear();
const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "@id": new URL("/#person", Astro.site).href,
  name: SITE_NAME,
  url: new URL("/", Astro.site).href,
  jobTitle: "Software Engineer",
  homeLocation: {
    "@type": "Place",
    name: "Cape Town, South Africa",
  },
  sameAs: SOCIAL_PROFILE_URLS,
};
---

<Layout
  title={SITE_NAME}
  description={SITE_DESCRIPTION}
  structuredData={personSchema}
>
  <main class="mx-8 h-screen max-w-[900px] pt-12 md:ml-[25%]">
    <div class="mb-12 flex flex-col">
      <h1 class="text-primary mb-2 text-xl font-bold">{SITE_NAME}</h1>
      <p class="text-secondary mb-2 text-lg">Software Engineer</p>
      <p class="text-accent mb-6">Cape Town, South Africa</p>
      <div class="flex w-full">
        <div class="text-primary inline-block text-center">
          <div class="flex items-center space-x-4">
            <a
              class="hover:bg-accent/25 rounded border border-gray-800 p-2 transition-colors duration-300"
              href="https://www.linkedin.com/in/dylanvanheerden/"
              aria-label="linkedin link"
              target="_blank"
              rel="noopener noreferrer"
            >
              <Image
                class="hover:scale-110 hover:cursor-pointer"
                src="/linkedin.svg"
                alt="linkedin image"
                width="24"
                height="24"
              />
            </a>
            <a
              class="hover:bg-accent/25 rounded border border-gray-800 p-2 transition-colors duration-300"
              href="https://github.com/dylanvanh"
              aria-label="github link"
              target="_blank"
              rel="noopener noreferrer"
            >
              <Image
                class="hover:scale-110 hover:cursor-pointer"
                src="/github.svg"
                alt="github image"
                width="24"
                height="24"
              />
            </a>
            <a
              class="hover:bg-accent/25 rounded border border-gray-800 p-2 transition-colors duration-300"
              href="https://x.com/obonobza"
              aria-label="X link"
              target="_blank"
              rel="noopener noreferrer"
            >
              <Image
                class="hover:scale-110 hover:cursor-pointer"
                src="/x.svg"
                alt="X image"
                width="24"
                height="24"
              />
            </a>
            <a
              class="hover:bg-accent/25 rounded border border-gray-800 p-2 transition-colors duration-300"
              href="mailto:dylanvanh45@gmail.com"
              aria-label="Open Mail"
              target="_blank"
              rel="noopener noreferrer"
            >
              <Image
                class="hover:scale-110 hover:cursor-pointer"
                src="/at-sign.svg"
                alt="@ sign image"
                width="24"
                height="24"
              />
            </a>
            <a
              class="text-primary hover:bg-accent/25 flex items-center gap-1 rounded border border-gray-800 px-3 py-2 text-sm transition-colors duration-300"
              href="/blog"
              data-astro-prefetch
            >
              Blog
              <span>→</span>
            </a>
          </div>
        </div>
      </div>
    </div>
    <section class="mb-12">
      <h2 class="font-heading text-primary mb-6 text-2xl font-bold">
        Experience
      </h2>
      <div class="space-y-6">
        {
          experienceItems.map((item) => (
            <ExperienceCard
              period={item.period}
              company={item.company}
              position={item.position}
              technologies={item.technologies}
            />
          ))
        }
      </div>
    </section>
    <section class="mb-12">
      <h2 class="font-heading text-primary mb-6 text-2xl font-bold">
        Projects
      </h2>
      <div class="w-5/6 space-y-6">
        {
          projectsItems.map((item) => (
            <ProjectCard
              title={item.title}
              href={item.href}
              websiteUrl={item.websiteUrl}
              technologies={item.technologies}
              primaryLinkAriaLabel={item.primaryLinkAriaLabel}
            />
          ))
        }
      </div>
    </section>
    <section class="mb-16">
      <h2 class="font-heading text-primary mb-4 text-2xl font-bold">
        Dev Environment
      </h2>

      <div class="text-primary mb-4 flex flex-row items-center space-x-2">
        <h3>Unix</h3>
        <Image src="/mac.svg" alt="Mac icon" width="23" height="23" />
        <Image src="/linux.svg" alt="Linux icon" width="27" height="27" />
      </div>
      <div class="mb-8 flex flex-wrap gap-2">
        {
          environmentItems.unix.map((item: EnvironmentItem) => (
            <ToolBadge name={item.name} href={item.href} />
          ))
        }
      </div>

      <div class="text-primary mb-4 flex flex-row items-center space-x-2">
        <h3>Windows</h3>
        <Image src="/windows.svg" alt="Windows icon" width="24" height="24" />
      </div>
      <div class="flex flex-wrap gap-2">
        {
          environmentItems.windows.map((item: EnvironmentItem) => (
            <ToolBadge name={item.name} href={item.href} />
          ))
        }
      </div>
    </section>
    <footer class="pb-12">
      <p class="text-accent">
        © {currentYear} Dylan van Heerden. All rights reserved.
      </p>
    </footer>
  </main>
</Layout>
