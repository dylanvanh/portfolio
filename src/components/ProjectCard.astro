---
import type { ProjectItem } from "../types/ProjectItem";

const { title, technologies, href, websiteUrl, primaryLinkAriaLabel } =
  Astro.props as ProjectItem;
---

<article class="py-5 first:pt-0 last:pb-0">
  <div class="flex min-w-0 items-center">
    <div class="flex min-w-0 flex-wrap items-center gap-x-4 gap-y-2">
      <a
        href={href}
        target="_blank"
        rel="noopener noreferrer"
        class="group inline-flex min-w-0 items-baseline gap-2.5 font-medium"
        aria-label={primaryLinkAriaLabel ?? `${title} GitHub repository`}
      >
        <span
          class="text-primary decoration-border group-hover:text-accent group-hover:decoration-accent underline decoration-1 underline-offset-4 transition-colors duration-150"
          >{title}</span
        >
        <span
          class="text-secondary group-hover:text-primary hidden shrink-0 text-xs font-normal transition-colors duration-150 sm:inline"
          aria-hidden="true">GitHub ↗</span
        >
        <svg
          class="text-secondary group-hover:text-primary size-3.5 shrink-0 transition-colors duration-150 sm:hidden"
          viewBox="0 0 24 24"
          fill="currentColor"
          aria-hidden="true"
        >
          <path
            d="M12 .3a12 12 0 0 0-3.8 23.4c.6.1.8-.3.8-.6v-2c-3.3.7-4-1.6-4-1.6-.6-1.4-1.4-1.8-1.4-1.8-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1.1 1.8 2.8 1.3 3.5 1 .1-.8.4-1.3.8-1.6-2.7-.3-5.5-1.3-5.5-5.9 0-1.3.5-2.4 1.2-3.2-.1-.3-.5-1.5.1-3.2 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0C17.3 5 18.3 5.3 18.3 5.3c.7 1.7.3 2.9.1 3.2.8.8 1.2 1.9 1.2 3.2 0 4.6-2.8 5.6-5.5 5.9.4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6A12 12 0 0 0 12 .3Z"
          ></path>
        </svg>
      </a>
      {
        websiteUrl && (
          <a
            href={websiteUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="text-accent hover:text-primary text-xs transition-colors duration-150"
            aria-label={`${title} live website`}
          >
            Live ↗
          </a>
        )
      }
    </div>
  </div>
  <div
    class="text-secondary mt-2 flex min-w-0 flex-wrap gap-x-2 text-sm leading-6"
  >
    {
      technologies.map((tech: string, index: number) => (
        <span class="flex items-center gap-2">
          {index > 0 && <span aria-hidden="true">•</span>}
          {tech}
        </span>
      ))
    }
  </div>
</article>
